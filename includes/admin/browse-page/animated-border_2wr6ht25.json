        "php": "$element_id = $element->get_id();\n$dd_style = isset( $settings['switcher_tvbcg225'] ) ? $settings['switcher_tvbcg225'] : '';\n\nif( $dd_style == 'Yes' ){\n  $element->add_render_attribute( '_wrapper', 'class', 'cwk-animated-border-one' );\n  $element->add_render_attribute( 'button', 'style', 'position: relative;' );\n}",
        "js": "",
        "php_after": "",
        "selected_lang": "php",
        "css": "\n.cwk-animated-border-one .elementor-button {\n  color: #566473;\n}\n.cwk-animated-border-one .elementor-button::after, \n.cwk-animated-border-one .elementor-button::before {\n  content: \"\";\n  display: block;\n  position: absolute;\n  width: 20%;\n  height: 20%;\n  border: 2px solid;\n  transition: all 0.6s ease;\n  border-radius: 2px;\n}\n.cwk-animated-border-one .elementor-button::after {\n  bottom: 0;\n  right: 0;\n  border-top-color: transparent;\n  border-left-color: transparent;\n  border-bottom-color: #566473;\n  border-right-color: #566473;\n}\n.cwk-animated-border-one .elementor-button::before {\n  top: 0;\n  left: 0;\n  border-bottom-color: transparent;\n  border-right-color: transparent;\n  border-top-color: #566473;\n  border-left-color: #566473;\n}\n.cwk-animated-border-one .elementor-button:hover:after, \n.cwk-animated-border-one .elementor-button:hover:before {\n  width: 100%;\n  height: 100%;\n}\n\n\n\n\n"
